{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "lib": ["ES2021", "DOM"],
    "noUncheckedIndexedAccess": false,

    "paths": {
      "@/*": ["./src/*"],
      // Type-level twin of vite.config.ts `resolve.dedupe`: the `link:`-ed
      // @orbat-mapper/tactical-draw* packages bundle their own maplibre-gl/ol,
      // so pin these to our single copy. Remove once those packages are
      // published to npm (see the `link:` deps in package.json).
      "maplibre-gl": ["./node_modules/maplibre-gl"],
      "ol": ["./node_modules/ol"],
      "ol/*": ["./node_modules/ol/*"]
    }
  }
}
